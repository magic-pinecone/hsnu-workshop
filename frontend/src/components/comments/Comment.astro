---
import { backendServer } from '../../consts';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const previewComments = [
  {
    name: 'HSNU Workshop',
    time: '15 分鐘前',
    body: '測試'
  },
  {
    name: 'a',
    time: '昨天',
    body: 'IDK'
  },
  {
    name: '路人',
    time: '昨天',
    body: 'なんで春日影やったの？'
  }
];

const avatarColors = ['#e9536a', '#2563eb', '#059669', '#7c3aed', '#d97706', '#0891b2'];

function hashName(name: string) {
  let hash = 0;

  for (const char of name) {
    hash = (hash * 31 + char.codePointAt(0)!) % avatarColors.length;
  }

  return hash;
}
---

<section
  class:list={['not-prose text-[var(--color-text)] dark:text-gray-200', className]}
  aria-labelledby="comments-title"
  data-backend-server={backendServer || undefined}
>
  <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="m-0 text-sm uppercase text-[var(--color-text-secondary)]">Comments</p>
      <h2 id="comments-title" class="mt-0.5 text-xl font-bold leading-snug">留言區</h2>
    </div>
    <span class="text-sm text-[var(--color-text-secondary)]">
      {previewComments.length} 則預覽留言
    </span>
  </div>

  <div
    class="mb-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-4 dark:bg-[var(--color-card-dark)]"
    aria-label="Comment form"
  >
    <textarea
      disabled
      rows="3"
      placeholder={backendServer ? '留言後端功能開發中' : '接上 backendServer 後即可留言'}
      class="w-full resize-y rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] p-3 font-[inherit] text-inherit dark:bg-[var(--color-bg-dark)]"
    ></textarea>
    <div class="mt-3 flex flex-col justify-between gap-3 sm:flex-row">
      <input
        disabled
        value="暱稱"
        aria-label="Nickname"
        class="w-full rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 font-[inherit] text-inherit sm:max-w-40 dark:bg-[var(--color-bg-dark)]"
      />
      <button disabled class="rounded-md bg-primary px-4 py-2 text-white">送出</button>
    </div>
  </div>

  <ol class="m-0 list-none p-0">
    {previewComments.map((comment) => (
      <li class="flex gap-3.5 border-b border-[var(--color-border)] py-4">
        <div
          class="grid size-11 shrink-0 place-items-center rounded-full font-bold text-white"
          style={`background-color: ${avatarColors[hashName(comment.name)]}`}
          aria-hidden="true"
        >
          {comment.name.slice(0, 1)}
        </div>
        <article class="min-w-0 flex-1">
          <header class="flex flex-wrap items-center justify-between gap-2">
            <strong>{comment.name}</strong>
            <time class="text-sm text-[var(--color-text-secondary)]">{comment.time}</time>
          </header>
          <p class="my-2 break-words leading-relaxed [overflow-wrap:anywhere]">{comment.body}</p>
        </article>
      </li>
    ))}
  </ol>
</section>
