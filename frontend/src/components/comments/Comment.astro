---
import { backendServer } from '../../consts';

interface Props {
  articleTitle?: string;
  class?: string;
}

const { articleTitle = Astro.url.pathname, class: className } = Astro.props;
---

<section
  class:list={['not-prose text-[var(--color-text)] dark:text-gray-200', className]}
  aria-labelledby="comments-title"
  data-comment-root
  data-backend-server={backendServer || undefined}
  data-article-name={articleTitle}
>
  <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="m-0 text-sm uppercase text-[var(--color-text-secondary)]">Comments</p>
      <h2 id="comments-title" class="mt-0.5 text-xl font-bold leading-snug">留言區</h2>
    </div>
  </div>

  <form
    class="mb-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] p-4 dark:bg-[var(--color-card-dark)]"
    aria-label="Comment form"
    data-comment-form
  >
    <textarea
      name="comment"
      disabled={!backendServer}
      maxlength="500"
      rows="3"
      placeholder={backendServer ? '留言後端功能開發中' : '接上 backendServer 後即可留言'}
      class="w-full resize-y rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] p-3 font-[inherit] text-inherit dark:bg-[var(--color-bg-dark)]"
    ></textarea>
    <div class="mt-3 flex flex-col justify-between gap-3 sm:flex-row">
      <input
        name="user_name"
        disabled={!backendServer}
        maxlength="50"
        placeholder="暱稱"
        aria-label="Nickname"
        class="w-full rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 font-[inherit] text-inherit sm:max-w-40 dark:bg-[var(--color-bg-dark)]"
      />
      <button disabled={!backendServer} class="rounded-md bg-primary px-4 py-2 text-white disabled:cursor-not-allowed disabled:opacity-60">
        送出
      </button>
    </div>
    <p class="mt-3 text-sm text-[var(--color-text-secondary)]" data-comment-status>
      {backendServer ? '正在載入留言……' : '尚未連接後端'}
    </p>
  </form>

  <ol class="m-0 list-none p-0" data-comment-list></ol>
</section>

<script>
  import { createComment, getComments, type CommentRecord } from '../../lib/comments';

  const avatarColors = ['#e9536a', '#2563eb', '#059669', '#7c3aed', '#d97706', '#0891b2'];

  function hashName(name: string) {
    let hash = 0;

    for (const char of name) {
      hash = (hash * 31 + char.codePointAt(0)!) % avatarColors.length;
    }

    return hash;
  }

  function escapeHtml(value: string) {
    const div = document.createElement('div');
    div.textContent = value;
    return div.innerHTML;
  }

  function formatDate(value: string) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) return value;

    return date.toLocaleString('zh-TW', {
      dateStyle: 'medium',
      timeStyle: 'short',
    });
  }

  function renderComments(list: HTMLOListElement, comments: CommentRecord[]) {
    if (comments.length === 0) {
      list.innerHTML = '<li class="py-4 text-sm text-[var(--color-text-secondary)]">目前沒有留言</li>';
      return;
    }

    list.innerHTML = comments
      .map((comment) => {
        const name = escapeHtml(comment.user_name);
        const content = escapeHtml(comment.comment);
        const time = escapeHtml(formatDate(comment.time));
        const avatarColor = avatarColors[hashName(comment.user_name)];

        return `
          <li class="flex gap-3.5 border-b border-[var(--color-border)] py-4">
            <div
              class="grid size-11 shrink-0 place-items-center rounded-full font-bold text-white"
              style="background-color: ${avatarColor}"
              aria-hidden="true"
            >
              ${name.slice(0, 1)}
            </div>
            <article class="min-w-0 flex-1">
              <header class="flex flex-wrap items-center justify-between gap-2">
                <strong>${name}</strong>
                <time class="text-sm text-[var(--color-text-secondary)]">${time}</time>
              </header>
              <p class="my-2 break-words leading-relaxed [overflow-wrap:anywhere]">${content}</p>
            </article>
          </li>
        `;
      })
      .join('');
  }

  function initCommentForms() {
    document.querySelectorAll<HTMLElement>('[data-comment-root]').forEach((root) => {
      const backendServer = root.dataset.backendServer;
      const articleName = root.dataset.articleName || location.pathname;
      const form = root.querySelector<HTMLFormElement>('[data-comment-form]');
      const list = root.querySelector<HTMLOListElement>('[data-comment-list]');
      const status = root.querySelector<HTMLElement>('[data-comment-status]');

      if (!backendServer || !form || !list || form.dataset.ready === 'true') return;

      form.dataset.ready = 'true';

      getComments(backendServer, articleName)
        .then((comments) => {
          renderComments(list, comments);
          if (status) status.textContent = '';
        })
        .catch(() => {
          renderComments(list, []);
          if (status) status.textContent = '後端尚未可用';
        });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const formData = new FormData(form);
        const userName = String(formData.get('user_name') || '').trim();
        const content = String(formData.get('comment') || '').trim();

        if (!userName || !content) {
          if (status) status.textContent = '請填寫暱稱與留言內容';
          return;
        }

        try {
          const comment = await createComment(backendServer, {
            article_name: articleName,
            user_name: userName,
            comment: content,
            time: new Date().toISOString(),
          });
          const currentComments = await getComments(backendServer, articleName).catch(() => [comment]);
          renderComments(list, currentComments);
          form.reset();
          if (status) status.textContent = '留言已送出';
        } catch {
          if (status) status.textContent = '送出失敗，請確認後端服務是否啟動';
        }
      });
    });
  }

  initCommentForms();
  document.addEventListener('astro:after-swap', initCommentForms);
</script>
